---
import { seoPages } from '../data/seoPages';

const year = new Date().getFullYear();
const planningLinks = seoPages;
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div>
        <a href="/" class="brand-mark small" aria-label="TripLion home">
          <img src="/assets/logo-lion.png" alt="" width="28" height="28" />
          <span>Trip<span>Lion</span></span>
        </a>
        <p class="footer-tagline">One calm place to plan every trip.</p>
      </div>
      <div>
        <h3>Product</h3>
        <a href="/features">TripLion Map</a>
        <a href="/#waitlist">Join waitlist</a>
        <a href="/blog">Blog</a>
        {planningLinks.map((page) => <a href={`/${page.slug}/`}>{page.eyebrow}</a>)}
      </div>
      <div>
        <h3>Company</h3>
        <a href="/contact">Contact</a>
        <a href="/q-and-a">Q&A</a>
      </div>
      <div>
        <h3>Legal</h3>
        <a href="/terms">Terms of Service</a>
        <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} TripLion. All rights reserved.</p>
      <div class="social-links" aria-label="Social links">
        <a href="https://x.com/triplionapp">X</a>
        <a href="https://instagram.com/triplionapp">Instagram</a>
        <a href="https://www.threads.net/@triplionapp">Threads</a>
      </div>
    </div>
  </div>
</footer>
