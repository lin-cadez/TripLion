---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/q-and-a', label: 'Q&A' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand-mark" aria-label="TripLion home">
      <img src="/assets/logo-lion.png" alt="" width="34" height="34" />
      <span>Trip<span>Lion</span></span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <a class="pill-button" href="/#waitlist">Join waitlist</a>
    </div>
    <details class="mobile-nav">
      <summary aria-label="Toggle navigation menu">Menu</summary>
      <nav class="mobile-nav-links" aria-label="Mobile primary">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="pill-button" href="/#waitlist">Join waitlist</a>
      </nav>
    </details>
  </div>
</header>
