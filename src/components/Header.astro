---
const navItems = [
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/q-and-a', label: 'Q&A' },
];
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand-mark" aria-label="TripLion home">
      <img src="/assets/logo-lion.png" alt="" width="34" height="34" />
      <span>Trip<span>Lion</span></span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <a class="pill-button" href="/#waitlist">Join waitlist</a>
    </div>
  </div>
</header>
