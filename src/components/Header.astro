---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/features', label: 'Features' },
  { href: '/blog', label: 'Blog' },
  { href: '/q-and-a', label: 'Q&A' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand-mark" aria-label="TripLion home">
      <img src="/assets/logo-lion.png" alt="" width="34" height="34" />
      <span>Trip<span>Lion</span></span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <a class="pill-button" href="/#waitlist">Join waitlist</a>
    </div>

    <button type="button" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>

  <div class="mobile-nav-backdrop" hidden></div>
  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile primary" hidden>
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    <a class="pill-button" href="/#waitlist">Join waitlist</a>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.querySelector<HTMLElement>('.mobile-nav');
  const backdrop = document.querySelector<HTMLElement>('.mobile-nav-backdrop');

  function closeMenu() {
    if (!toggle || !menu || !backdrop) return;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.classList.remove('is-open');
    menu.hidden = true;
    backdrop.hidden = true;
    document.body.classList.remove('nav-open');
  }

  function openMenu() {
    if (!toggle || !menu || !backdrop) return;
    toggle.setAttribute('aria-expanded', 'true');
    toggle.classList.add('is-open');
    menu.hidden = false;
    backdrop.hidden = false;
    document.body.classList.add('nav-open');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  backdrop?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
  window.addEventListener('resize', () => {
    if (window.innerWidth > 900) closeMenu();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });
</script>
