---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { seoPages } from '../data/seoPages';

const features = [
  {
    number: '01',
    title: 'Itinerary and map, one view',
    body: 'See every stop, stay, and route on the same screen, without tab-switching between apps.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4.5 4 6.5v13l5-2 6 2 5-2v-13l-5 2-6-2Z"/><path d="M9 4.5v13"/><path d="M15 6.5v13"/><circle cx="12" cy="12.2" r="1.4" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    number: '02',
    title: 'AI-assisted discovery and one-click navigation',
    body: 'Search for places in plain language, then open Google Maps navigation to any stop in a single click.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"/><path d="m19.5 19.5-4.2-4.2"/><path d="M10.5 7.5v6"/><path d="M7.5 10.5h6"/><path d="M18.5 3.5v3M17 5h3" stroke-width="1.3"/></svg>`,
  },
  {
    number: '03',
    title: 'Share the plan and keep reservations organized',
    body: 'Invite friends to co-edit the itinerary, and attach notes and reservation details to each destination.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="12" r="2.3"/><circle cx="18" cy="5.5" r="2.3"/><circle cx="18" cy="18.5" r="2.3"/><path d="m8.1 10.8 7.8-4.4"/><path d="m8.1 13.2 7.8 4.4"/></svg>`,
  },
];

const planningPages = seoPages;
const topBlogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<Layout
  title="TripLion Map — Plan every trip in one clear view"
  description="TripLion Map brings your itinerary, map, AI-assisted discovery, one-click navigation, and trip sharing into one organized, encrypted travel plan."
  path="/"
  ogImage="/assets/product/triplion-itinerary-map.webp"
>
  <main>
    <section class="landing-hero">
      <div class="container hero-center">
        <p class="status-pill">In pre-release</p>
        <h1>The itinerary and the map, finally in one place.</h1>
        <p class="hero-lede">
          Build your route, discover places with AI-assisted search, open Google Maps navigation
          in one click, and plan together with the people joining you.
        </p>
        <form id="waitlist" class="waitlist-form" action="https://formspree.io/f/mkoalrzq" method="POST" aria-label="TripLion waitlist form">
          <label class="sr-only" for="email">Email address</label>
          <input id="email" name="email" type="email" placeholder="you@email.com" autocomplete="email" required />
          <input type="hidden" name="form-name" value="homepage-waitlist" />
          <input type="hidden" name="message" value="Add me to the TripLion early access waitlist." />
          <button type="submit">Join waitlist</button>
        </form>
        <p class="form-note">Free while we&rsquo;re in pre-release. Your trip data is encrypted in transit and at rest.</p>
      </div>
    </section>

    <section class="product-preview container" aria-label="TripLion product preview">
      <div class="browser-frame">
        <div class="browser-canvas">
          <div class="browser-top" aria-hidden="true">
            <div class="browser-tab-row">
              <span class="traffic red"></span>
              <span class="traffic yellow"></span>
              <span class="traffic green"></span>
              <div class="browser-tab">
                <span></span>
                New Tab
              </div>
            </div>
            <div class="browser-address-row">
              <span class="browser-dot"></span>
              <div class="browser-address">
                <span></span>
                app.trip-lion.com/trip/iceland
              </div>
              <span class="browser-dot"></span>
            </div>
          </div>
          <img
            src="/assets/product/triplion-itinerary-map.webp"
            alt="TripLion itinerary and map view for a road trip"
            width="1600"
            height="950"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <section class="feature-strip container">
      {features.map((feature) => (
        <article>
          <p>{feature.number}</p>
          <span class="feature-icon" aria-hidden="true" set:html={feature.icon} />
          <h2>{feature.title}</h2>
          <p>{feature.body}</p>
        </article>
      ))}
    </section>

    <section class="section-band">
      <div class="container">
        <div class="section-heading center">
          <h2>One product, several ways to start planning</h2>
          <p class="section-subtitle">
            TripLion Map is a single tool, but people arrive at it from different angles &mdash;
            starting from a route, a destination, or a group of friends. Pick the guide closest to
            how you&rsquo;re already thinking about this trip.
          </p>
        </div>
        <div class="card-grid seo-link-grid">
          {planningPages.map((page) => (
            <a class="feature-card" href={`/${page.slug}/`}>
              <p class="card-meta">{page.eyebrow}</p>
              <h3>{page.h1}</h3>
              <p>{page.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section container">
      <div class="section-heading">
        <h2>From the blog</h2>
      </div>
      <div class="blog-grid compact">
        {topBlogPosts.map((post) => (
          <a class="blog-card" href={`/blog/${post.slug}/`}>
            <img src={post.data.image} alt={post.data.imageAlt} loading="lazy" width="640" height="360" />
            <div class="blog-card-body">
              <p class="card-meta">{post.data.category}</p>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="cta-band">
      <div class="container">
        <h2>Ready for a calmer way to plan?</h2>
        <p>Join the waitlist and be first in when we open the doors.</p>
        <a class="pill-button dark" href="#waitlist">Join the waitlist</a>
      </div>
    </section>
  </main>

  <script>
    const form = document.querySelector<HTMLFormElement>('.waitlist-form');
    if (form) {
      const note = document.querySelector<HTMLElement>('.form-note');
      const button = form.querySelector<HTMLButtonElement>('button');
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!button || !note) return;
        const original = button.textContent;
        button.disabled = true;
        button.textContent = 'Joining...';
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (!response.ok) throw new Error('Submission failed');
          form.reset();
          note.textContent = "You're on the list. We'll email you when your spot opens up.";
          note.classList.add('success');
        } catch {
          note.textContent = 'Something went wrong. Please try again.';
          note.classList.remove('success');
        } finally {
          button.disabled = false;
          button.textContent = original;
        }
      });
    }
  </script>
</Layout>
