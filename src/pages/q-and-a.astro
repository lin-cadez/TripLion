---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    question: 'What is TripLion Map?',
    answer: 'TripLion Map is our first product. It keeps your itinerary, map, stops, and planning notes together in one view.',
  },
  {
    question: 'Is TripLion in beta?',
    answer: 'Not yet. TripLion is currently in pre-release and access is managed through the waitlist.',
  },
  {
    question: 'Can TripLion help me discover places?',
    answer: 'Yes. You can use AI-assisted search to discover stops that match your route and travel style.',
  },
  {
    question: 'Can I navigate with Google Maps?',
    answer: 'Yes. Open one-click Google Maps navigation from a destination when you are ready to drive.',
  },
  {
    question: 'Can I plan trips with friends?',
    answer: 'Yes. Share your trip with friends, let them edit the plan, and keep everyone aligned in one itinerary.',
  },
  {
    question: 'Can I save notes and reservations?',
    answer: 'Yes. Add notes and reservation details to specific destinations so important info stays organized.',
  },
  {
    question: 'Is my trip data encrypted?',
    answer: 'Yes. Trip data is encrypted in transit and at rest.',
  },
  {
    question: 'Will it cost anything?',
    answer: 'TripLion is free during the pre-release period. We will communicate clearly before any pricing changes.',
  },
  {
    question: 'How do I get help if something breaks?',
    answer: 'Email hello@trip-lion.com or use the contact form. We read every message ourselves.',
  },
];
---
<Layout
  title="Q&A — TripLion"
  description="Answers to common questions about TripLion Map, pre-release access, AI discovery, navigation, sharing, data encryption, and support."
  path="/q-and-a"
>
  <main class="qa-page">
    <section class="container qa-inner">
      <h1>Q&A</h1>
      <p>Answers to what people ask us most. Still stuck? <a href="/contact">Contact us</a>.</p>
      <div class="faq-list">
        {faqs.map((faq, index) => (
          <details open={index === 0}>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
</Layout>
