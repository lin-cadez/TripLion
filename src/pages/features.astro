---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    slug: 'ai-chat',
    title: 'Ask for the stop you mean',
    body: 'TripLion understands the difference between "find me a quiet beach" and "find me a quick food stop close to the highway." Ask natural questions about the route and turn useful answers into actual stops.',
  },
  {
    slug: 'explore-discover',
    title: 'Explore and discover',
    body: 'Search restaurants, cafes, hotels, museums, parks, shops, and attractions, or describe what you want in plain language. Results stay relevant to the route, so you are not sorting through places three hours away.',
  },
  {
    slug: 'interactive-map',
    title: 'Interactive map',
    body: 'See every stop on one map. Check photos, ratings, hours, contact details, transit options, satellite imagery, and Street View without losing the wider route.',
  },
  {
    slug: 'save-organize',
    title: 'Save and organize',
    body: 'Found ten places you like and time for only three? Save them into practical lists such as must-see attractions or backup restaurants, directly from search results or the map.',
  },
  {
    slug: 'share-trips',
    title: 'Share trips and lists',
    body: 'Every trip and saved list can become a shareable link. Send it to the people traveling with you so everyone can see the plan without digging through a message thread.',
  },
  {
    slug: 'export-print',
    title: 'Export and print',
    body: 'Export a detailed PDF with maps, routes, addresses, and timelines, or use a clean layout with just the schedule. It is useful when signal is unreliable or a phone is not the best screen.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://trip-lion.com/' },
    { '@type': 'ListItem', position: 2, name: 'Features', item: 'https://trip-lion.com/features' },
  ],
};
---
<Layout
  title="Road Trip Planner Features | TripLion"
  description="Explore TripLion features for route-aware discovery, multi-day itineraries, interactive maps, saved lists, trip sharing, and PDF export."
  path="/features"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <main>
    <section class="page-intro container">
      <p class="eyebrow">TripLion Map features</p>
      <h1>Everything TripLion Map includes today</h1>
      <p>Discover promising stops, organize the itinerary, share it with your group, and take a clean copy on the road.</p>
    </section>
    <section class="section container">
      <div class="card-grid">
        {features.map((feature, index) => (
          <div id={feature.slug} class="feature-card">
            <span class="feature-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <h2>{feature.title}</h2>
            <p>{feature.body}</p>
          </div>
        ))}
      </div>
      <div class="final-cta">
        <a href="https://app.trip-lion.com" class="cta-button">Open TripLion</a>
      </div>
    </section>
  </main>
</Layout>
